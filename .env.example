PROXY_ALWAYS_ON=1
PROXY_BACKEND_URL=http://localhost:3333
PROXY_CLOUDFLARE_SUPPORT=false
PROXY_MAX_CONN=200
PROXY_MAX_REQ=1500
PROXY_WHITELIST_RATE=10
PROXY_WHITELIST_UA=Googlebot,bingbot,DuckDuckBot,Applebot,facebookexternalhit,Twitterbot,LinkedInBot,Discordbot
PORT=443
PROXY_AUTO_MITIGATION_ON_TIMEOUT=true
PROXY_CACHE_ENABLED=1
PROXY_MAX_FAILED_CHALLENGES=100
PROXY_MAX_TIMEOUTS=5
PROXY_PROMETHEUS_ENABLED=true
PROXY_TIMEOUT_THRESHOLD=3s
PROXY_ENABLE_SSL=true
PROXY_HTTP_PORT=80
PROXY_XDP_INTERFACE=eth0
PROXY_POW_DIFFICULTY=4

# Optional Turnstile (omit to use built-in Proof-of-Work). Note: must be the
# exact names below — an X_ prefix disables them.
# PROXY_TURNSTILE_PUBLIC_KEY=
# PROXY_TURNSTILE_PRIVATE_KEY=

# ACME (HTTPS). For ZeroSSL / providers requiring EAB, set all three.
PROXY_ACME_DIRECTORY_URL=https://acme.zerossl.com/v2/DV90
PROXY_ACME_EMAIL=you@example.com
PROXY_ACME_EAB_KEY_ID=
PROXY_ACME_EAB_HMAC=
